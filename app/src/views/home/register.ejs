<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/home/login.css">
    <script src="/js/home/register.js" defer></script>
    <title>Document</title>
    <style>
    .jb-white{
        color: white;
    }</style>
</head>
<body>
    <div class="login-box">
        <h2>Login</h2>
        <form>
          <div class="user-box">
            <input id="id" type="text" name="" required="">
            <label>아이디</label>
          </div>
          <div class="user-box">
            <input id="name" type="text" name="" required="">
            <label>이름</label>
          </div>
          <div class="user-box">
            <input id="psword" type="password" name="" required="">
            <label>패스워드</label>
          </div>
          <div class="user-box">
            <input id="confirm-psword" type="password" name="" required="">
            <label>패스워드 확인</label>
          </div>
          <p id="button">Sign Up</p>
          <p class="jb-white">Already registered? <a href="/login">login</a></p>

          
          
        </form>
      </div>
</body>
</html>

